---
import LayoutPrado from "../layouts/LayoutPrado.astro";
---

<LayoutPrado>
  <h1>Registro</h1>

  <form id="form-registro" class="form">
    <input type="email" id="email" placeholder="Correo" required />
    <input type="password" id="password" placeholder="Contraseña" required />
    <button type="submit">Crear cuenta</button>
  </form>

  <p>¿Ya tienes cuenta? <a href="/login">Inicia sesión</a></p>

  <script>
    document.getElementById("form-registro").addEventListener("submit", (e) => {
      e.preventDefault();

      const email = document.getElementById("email").value;
      const password = document.getElementById("password").value;

      let usuarios = JSON.parse(localStorage.getItem("usuarios")) || [];

      if (usuarios.find((u) => u.email === email)) {
        if (window.toast) window.toast("Este correo ya está registrado", "error", 3500);
        else alert("Este correo ya está registrado");
        return;
      }

      usuarios.push({ email, password });
      localStorage.setItem("usuarios", JSON.stringify(usuarios));

      if (window.toast) {
        window.toast("Cuenta creada correctamente", "success", 2500);
        setTimeout(() => { window.location.href = "/login"; }, 700);
      } else {
        alert("Cuenta creada correctamente");
        window.location.href = "/login";
      }
    });
  </script>
</LayoutPrado>
