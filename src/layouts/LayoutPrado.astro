---
const { children } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Galería del Prado</title>
    <link rel="stylesheet" href="/styles/global.css">
  </head>

  <body>
    <header>
      <div class="header-inner">
        <a href="/" class="logo">
          <span class="logo-text">Galería del Prado</span>
        </a>

        <nav class="menu">
          <a href="/" class="nav-link">Inicio</a>
          <a href="/galeria" class="nav-link">Galería</a>
          <a href="/destacados" class="nav-link">Destacados</a>
          <a href="/carrito" class="nav-link nav-carrito" title="Ver carrito">
            <span class="carrito-icono">🛒</span>
            <span class="carrito-texto">Carrito</span>
            <span id="contador-carrito" class="carrito-badge"></span>
          </a>
          <span id="usuario-menu" class="usuario-menu"></span>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <script>
      function actualizarContador() {
        const data = JSON.parse(localStorage.getItem('carrito')) || [];
        const total = data.reduce((acc, item) => {
          return acc + (typeof item === "string" ? 1 : (item.cantidad || 1));
        }, 0);
        const span = document.getElementById("contador-carrito");
        if (span) {
          span.innerText = total > 0 ? total : "";
          span.style.display = total > 0 ? "inline-flex" : "none";
        }
      }
      actualizarContador();
      window.actualizarContador = actualizarContador;

      function obtenerUsuario() {
        try {
          return JSON.parse(sessionStorage.getItem("usuario")) ||
                 JSON.parse(localStorage.getItem("usuario"));
        } catch (e) {
          return null;
        }
      }

      function mostrarUsuario() {
        const usuario = obtenerUsuario();
        const contenedor = document.getElementById("usuario-menu");

        if (usuario) {
          const inicial = (usuario.email || "U").charAt(0).toUpperCase();
          contenedor.innerHTML = `
            <div class="usuario-wrap">
              <button class="usuario-btn" id="usuarioBtn" type="button" title="${usuario.email}">
                <span class="usuario-avatar">${inicial}</span>
                <span class="usuario-nombre">${(usuario.email || '').split('@')[0]}</span>
                <span class="usuario-flecha">▾</span>
              </button>
              <div class="usuario-dropdown" id="usuarioDropdown">
                <div class="dropdown-header">
                  <div class="dropdown-avatar">${inicial}</div>
                  <div>
                    <strong>${(usuario.email || '').split('@')[0]}</strong>
                    <small>${usuario.email}</small>
                  </div>
                </div>
                <a href="/carrito" class="dropdown-item">
                  <span>🛒</span> Mi carrito
                </a>
                <button type="button" class="dropdown-item dropdown-logout" id="logout">
                  <span>🚪</span> Cerrar sesión
                </button>
              </div>
            </div>
          `;

          const btn = document.getElementById("usuarioBtn");
          const dropdown = document.getElementById("usuarioDropdown");

          btn.addEventListener("click", (e) => {
            e.stopPropagation();
            dropdown.classList.toggle("dropdown-open");
          });

          document.addEventListener("click", () => {
            dropdown.classList.remove("dropdown-open");
          });

          document.getElementById("logout").addEventListener("click", () => {
            localStorage.removeItem("usuario");
            sessionStorage.removeItem("usuario");
            if (window.toast) {
              window.toast("Sesión cerrada correctamente", "info", 2500);
            }
            setTimeout(() => window.location.reload(), 500);
          });
        } else {
          contenedor.innerHTML = `
            <a href="/login" class="btn-login" title="Iniciar sesión">
              <span class="login-icono">👤</span>
              <span class="login-texto">Iniciar sesión</span>
            </a>
          `;
        }
      }
      mostrarUsuario();
    </script>

    <!-- Sistema de notificaciones toast -->
    <script src="/scripts/toast.js" is:inline></script>
  </body>
</html>
