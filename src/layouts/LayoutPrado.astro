---
const { children } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Galería del Prado</title>
    <link rel="stylesheet" href="/styles/global.css">
  </head>

  <body>
    <header>
      <h1>Galería del Prado</h1>

      <nav class="menu">
        <a href="/">Inicio</a>
        <a href="/galeria">Galería</a>
        <a href="/destacados">Destacados</a>
        <a href="/carrito">Carrito <span id="contador-carrito"></span></a>
        <span id="usuario-menu"></span>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <script>
      function actualizarContador() {
        const carrito = JSON.parse(localStorage.getItem('carrito')) || [];
        const span = document.getElementById("contador-carrito");
        if (span) span.innerText = `(${carrito.length})`;
      }
      actualizarContador();
      window.actualizarContador = actualizarContador;

      function mostrarUsuario() {
        const usuario = JSON.parse(localStorage.getItem("usuario"));
        const contenedor = document.getElementById("usuario-menu");

        if (usuario) {
          contenedor.innerHTML = `
            <span>Hola, ${usuario.email}</span>
            <button id="logout" style="margin-left:10px;">Salir</button>
          `;
          document.getElementById("logout").onclick = () => {
            localStorage.removeItem("usuario");
            if (window.toast) {
              window.toast("Sesión cerrada correctamente", "info", 2500);
            } else {
              alert("Sesión cerrada");
            }
            setTimeout(() => window.location.reload(), 600);
          };
        } else {
          contenedor.innerHTML = `<a href="/login">Iniciar sesión</a>`;
        }
      }
      mostrarUsuario();
    </script>

    <!-- Sistema de notificaciones toast -->
    <script src="/scripts/toast.js" is:inline></script>
  </body>
</html>
